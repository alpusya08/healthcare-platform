# ─── PostgreSQL (main DB for backend) ───────────────────────────
POSTGRES_DB=healthcare
POSTGRES_USER=healthcare
POSTGRES_PASSWORD=healthcare_secret
POSTGRES_PORT=5432

# ─── PostgreSQL (AI service DB for feedback) ────────────────────
AI_POSTGRES_DB=ai_feedback
AI_POSTGRES_USER=ai_feedback
AI_POSTGRES_PASSWORD=ai_feedback_secret

# ─── Redis ──────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── MinIO ──────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=medical-files

# ─── MLflow ─────────────────────────────────────────────────────
MLFLOW_PORT=5000

# ─── Backend (Java) ─────────────────────────────────────────────
BACKEND_PORT=8080
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-256-bits-for-hs512
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P30D
SPRING_PROFILES_ACTIVE=dev

# ─── AI Service (Python) ────────────────────────────────────────
AI_SERVICE_PORT=8000
AI_SERVICE_INTERNAL_TOKEN=internal-shared-secret-between-backend-and-ai

# ─── LLM Providers ──────────────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Frontend ───────────────────────────────────────────────────
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_AI_SERVICE_URL=http://localhost:8000

# ─── CORS ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
